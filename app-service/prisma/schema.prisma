generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model System {
  id          String   @id @default(uuid())
  slug        String   @unique // Unique identifier for ghost user IDs (e.g. "chiara")
  pkId        String?  // PluralKit-compatible random ID (e.g. "abcde")
  name        String?
  description String?
  pronouns    String?
  avatarUrl   String?
  banner      String?
  color       String?
  systemTag   String?  // The suffix tag (e.g. ⛩️ Seraphim ⛩️)
  autoproxyMode String @default("off") // "off", "latch", "member"
  autoproxyId String?
  autoproxy   Member?  @relation("Autoproxy", fields: [autoproxyId], references: [id])
  members     Member[] @relation("SystemMembers")
  groups      Group[]  @relation("SystemGroups")
  accountLinks AccountLink[]
  deviceRegistered Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AccountLink {
  matrixId String @id // The full Matrix Identifier (@user:domain)
  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  isPrimary Boolean @default(false)
}

model Member {
  id          String   @id @default(uuid())
  systemId    String
  system      System   @relation("SystemMembers", fields: [systemId], references: [id], onDelete: Cascade)
  autoproxiedSystems System[] @relation("Autoproxy")
  slug        String   // Name-based ID for commands (e.g. "lily")
  pkId        String?  // PluralKit-compatible random ID (e.g. "abcde")
  name        String
  displayName String?
  avatarUrl   String?
  pronouns    String?
  description String?
  color       String?
  proxyTags   Json     // Array of { prefix: string, suffix: string }
  matrixId    String?  // The Ghost User ID (@_plural_id:server)
  groups      Group[]  @relation("MemberGroups")
  deviceRegistered Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([systemId, slug])
  @@unique([systemId, pkId])
}

model Group {
  id          String   @id @default(uuid())
  systemId    String
  system      System   @relation("SystemGroups", fields: [systemId], references: [id], onDelete: Cascade)
  slug        String   // Name-based ID for commands
  pkId        String?  // PluralKit-compatible random ID
  name        String
  displayName String?
  description String?
  icon        String?  // Avatar/icon URL
  color       String?
  members     Member[] @relation("MemberGroups")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([systemId, slug])
  @@unique([systemId, pkId])
}
